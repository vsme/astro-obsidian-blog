---
interface Props {
  totalRecords: number;
}

const { totalRecords } = Astro.props;
---

<time-river-hero>
  <section class="time-river-hero" aria-labelledby="time-river-title">
    <canvas class="time-river-canvas" aria-hidden="true"></canvas>

    <div class="time-river-inner">
      <div class="time-river-copy">
        <p class="time-river-eyebrow">
          <span>时间档案</span>
          <span aria-hidden="true">/</span>
          <span>{String(totalRecords).padStart(2, "0")} 条记录</span>
        </p>
        <h1 id="time-river-title" class="sr-only">时间档案</h1>
        <p class="time-river-description">在日常里，留下那些值得回望的片段。</p>
      </div>
    </div>
  </section>
</time-river-hero>

<style>
  time-river-hero {
    position: relative;
    z-index: 0;
    display: block;
    width: 100%;
    margin: -3rem auto 0;
  }

  .time-river-hero {
    position: relative;
    isolation: isolate;
    display: flex;
    width: 100%;
    max-width: none;
    margin: 0;
    min-height: 11rem;
    overflow: hidden;
  }

  .time-river-canvas {
    position: absolute;
    z-index: 0;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-18px);
    transition: opacity 900ms ease;
  }

  .time-river-canvas.is-ready {
    opacity: 1;
  }

  :global(html[data-theme="dark"]) .time-river-canvas {
    transform: translateY(-26px);
  }

  .time-river-inner {
    position: relative;
    z-index: 1;
    display: grid;
    width: 100%;
    max-width: 48rem;
    margin: auto;
    padding: 0rem 1rem 1.75rem;
    pointer-events: none;
  }

  .time-river-copy {
    max-width: 35rem;
    transform: translateY(2.5rem);
  }

  .time-river-eyebrow {
    display: flex;
    gap: 0.65rem;
    align-items: center;
    margin: 0 0 1rem;
    color: color-mix(in srgb, var(--foreground) 54%, transparent);
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.68rem;
    line-height: 1;
    letter-spacing: 0.16em;
  }

  .time-river-description {
    max-width: 28rem;
    margin: 0;
    color: color-mix(in srgb, var(--foreground) 76%, transparent);
    font-size: clamp(1rem, 2vw, 1.15rem);
    letter-spacing: 0.025em;
  }

  @media (max-width: 639px) {
    time-river-hero {
      margin-top: -3.25rem;
    }

    .time-river-hero {
      min-height: 10rem;
    }

    .time-river-inner {
      padding: 0;
    }

    .time-river-copy {
      transform: translateY(2rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .time-river-canvas {
      transition: none;
    }
  }
</style>

<script>
  const FADE_WIDTH = 0.48;
  const EROSION_STRENGTH = 0.11;
  const FLOW_SPEED = 0.4;
  const TURBULENCE_LIGHT = 2.7;
  const TURBULENCE_DARK = 3.2;
  const SPECULAR_INTENSITY = 0.195;
  const SPECULAR_INTENSITY_LIGHT = 0.16;
  const RIVER_DEPTH = 64;
  const MAX_TRAILS = 10;
  const TRAIL_LIFETIME = 1800;
  const TRAIL_SAMPLE_INTERVAL = 38;
  const TRAIL_FORCE_DISTANCE = 18;
  const TOUCH_TAP_MAX_DURATION = 500;
  const TOUCH_TAP_MAX_DISTANCE = 12;

  interface Trail {
    fromX: number;
    fromY: number;
    x: number;
    y: number;
    deltaX: number;
    deltaY: number;
    createdAt: number;
    speed: number;
  }

  interface PointerPosition {
    x: number;
    y: number;
    time: number;
  }

  interface TouchStart extends PointerPosition {
    pointerId: number;
  }

  const clamp = (value: number, minimum: number, maximum: number) =>
    Math.min(maximum, Math.max(minimum, value));

  const WATER_DEEP_DARK = new Float32Array([0.004, 0.184, 0.245]);
  const WATER_SHALLOW_DARK = new Float32Array([0.0, 0.085, 0.171]);
  const WATER_SPECULAR_DARK = new Float32Array([1.0, 1.0, 1.0]);
  const WATER_SKY_DARK = new Float32Array([0.569, 1.0, 1.0]);
  const BACKGROUND_DARK = new Float32Array([0.126, 0.126, 0.141]);
  const WATER_DEEP_LIGHT = new Float32Array([0.781, 0.958, 0.98]);
  const WATER_SHALLOW_LIGHT = new Float32Array([0.911, 0.95, 1.0]);
  const WATER_SPECULAR_LIGHT = new Float32Array([1.0, 1.0, 1.0]);
  const WATER_SKY_LIGHT = new Float32Array([0.82, 0.894, 1.0]);
  const BACKGROUND_LIGHT = new Float32Array([0.992, 0.992, 0.992]);

  const VERTEX_SHADER = `#version 300 es
    precision highp float;

    const int MAX_TRAILS = ${MAX_TRAILS};
    const float PLANE_WIDTH = 240.0;
    const float PLANE_DEPTH = ${RIVER_DEPTH.toFixed(1)};

    in vec2 aPosition;
    in vec2 aUv;

    uniform mat4 uProjectionMatrix;
    uniform mat4 uViewMatrix;
    uniform float uTime;
    uniform float uSpeed;
    uniform float uTurbulence;
    uniform float uFadeWidth;
    uniform vec2 uSurfaceSize;
    uniform float uRippleRadius;
    uniform int uTrailCount;
    uniform vec4 uTrails[MAX_TRAILS];
    uniform vec4 uTrailMotion[MAX_TRAILS];

    out vec3 vWorldPosition;
    out vec3 vNormal;
    out vec2 vUv;

    float getWaveHeight(float x, float y, float time, float speed, float turb) {
      float w1 = sin(x * 0.08 - time * speed * 2.0) * 1.5 * turb;
      float w2 = cos(x * 0.18 + y * 0.12 + time * speed * 3.2) * 0.5 * turb;
      float w3 = sin(y * 0.45 - time * speed * 1.2) * 0.25 * turb;
      return w1 + w2 + w3;
    }

    vec2 projectToSurface(vec3 position) {
      vec4 clipPosition = uProjectionMatrix *
        uViewMatrix *
        vec4(position, 1.0);
      vec2 normalizedPosition = clipPosition.xy /
        max(abs(clipPosition.w), 0.0001);
      return vec2(
        normalizedPosition.x * 0.5 + 0.5,
        0.5 - normalizedPosition.y * 0.5
      ) * uSurfaceSize;
    }

    float getPointerWave(vec2 surfacePosition) {
      float pointerWave = 0.0;

      for (int index = 0; index < MAX_TRAILS; index += 1) {
        if (index >= uTrailCount) break;

        vec4 trail = uTrails[index];
        vec4 motion = uTrailMotion[index];
        vec2 segment = trail.zw - trail.xy;
        float segmentLengthSquared = dot(segment, segment);
        if (segmentLengthSquared < 0.0001) continue;

        float age = max(0.0, uTime - motion.z);
        if (age > ${TRAIL_LIFETIME / 1000}) continue;

        float speedRatio = clamp(motion.w / 20.0, 0.0, 1.0);
        float segmentLength = sqrt(segmentLengthSquared);
        vec2 tangent = segment / segmentLength;
        vec2 relative = surfacePosition - trail.xy;
        float projection = clamp(
          dot(relative, segment) / segmentLengthSquared,
          0.0,
          1.0
        );
        vec2 closestPoint = trail.xy + segment * projection;
        vec2 fromPath = surfacePosition - closestPoint;
        float pathDistance = length(fromPath);
        float growth = clamp(
          age / ${TRAIL_LIFETIME / 1000},
          0.0,
          1.0
        );
        float waveRadius = 5.0 + age * uRippleRadius * 0.95;
        float waveThickness = mix(
          8.0,
          19.0,
          smoothstep(0.0, 1.0, growth)
        );
        float waveOffset = pathDistance - waveRadius;
        float recency = float(index + 1) /
          max(float(uTrailCount), 1.0);
        float trailWeight = mix(0.56, 1.0, recency);
        float life = exp(-age * 2.15) *
          (1.0 - smoothstep(1.35, ${TRAIL_LIFETIME / 1000}, age));
        float organic =
          sin(surfacePosition.x * 0.041 + surfacePosition.y * 0.057) * 0.55 +
          sin(surfacePosition.x * 0.019 - surfacePosition.y * 0.033) * 0.35;
        float waveEnvelope = exp(-pow(
          waveOffset / (waveThickness * 1.75),
          2.0
        ));
        float wave = (
          cos(waveOffset * 0.21 + organic * 0.22) +
          cos(waveOffset * 0.105 - organic * 0.15) * 0.22
        ) * waveEnvelope;
        float wakeAmplitude = mix(0.55, 3.0, speedRatio) *
          trailWeight * life;
        pointerWave += wave * wakeAmplitude;

        if (index == uTrailCount - 1) {
          vec2 fromHead = surfacePosition - trail.zw;
          float headDistance = length(fromHead);
          float contactRadius = mix(10.0, 19.0, speedRatio);
          float pressure = 1.0 - smoothstep(
            contactRadius * 0.18,
            contactRadius,
            headDistance
          );
          float rim = exp(-pow(
            (headDistance - contactRadius) / (contactRadius * 0.42),
            2.0
          ));
          float forward = dot(fromHead, tangent);
          float bowBias = mix(
            0.72,
            1.22,
            smoothstep(-contactRadius, contactRadius, forward)
          );
          float headAmplitude = mix(1.2, 4.2, speedRatio) *
            exp(-age * 12.0);
          pointerWave += (rim - pressure * 0.42) *
            headAmplitude * bowBias;
        }
      }

      return 4.5 * tanh(pointerWave / 4.5);
    }

    float getSurfaceHeight(vec2 planePosition, vec2 uv) {
      float lowerFade = smoothstep(0.0, uFadeWidth, uv.y);
      float upperFade = 1.0 - smoothstep(
        1.0 - uFadeWidth,
        1.0,
        uv.y
      );
      float borderFactor = lowerFade * upperFade;
      float ambientHeight = getWaveHeight(
        planePosition.x,
        planePosition.y,
        uTime,
        uSpeed,
        uTurbulence
      );
      vec3 ambientPosition = vec3(
        planePosition.x,
        ambientHeight * borderFactor,
        planePosition.y
      );
      float pointerHeight = getPointerWave(
        projectToSurface(ambientPosition)
      );
      return (ambientHeight + pointerHeight) * borderFactor;
    }

    void main() {
      vUv = aUv;
      float displacedHeight = getSurfaceHeight(aPosition, aUv);
      vec3 displacedPosition = vec3(
        aPosition.x,
        displacedHeight,
        aPosition.y
      );

      vWorldPosition = displacedPosition;

      float epsilon = 0.15;
      vec2 rightPosition = aPosition + vec2(epsilon, 0.0);
      vec2 forwardPosition = aPosition + vec2(0.0, epsilon);
      vec2 rightUv = aUv + vec2(epsilon / PLANE_WIDTH, 0.0);
      vec2 forwardUv = aUv + vec2(0.0, epsilon / PLANE_DEPTH);
      float rightHeight = getSurfaceHeight(rightPosition, rightUv);
      float forwardHeight = getSurfaceHeight(forwardPosition, forwardUv);
      vec3 tangent = vec3(epsilon, rightHeight - displacedHeight, 0.0);
      vec3 binormal = vec3(0.0, forwardHeight - displacedHeight, epsilon);
      vNormal = normalize(cross(binormal, tangent));

      gl_Position = uProjectionMatrix *
        uViewMatrix *
        vec4(displacedPosition, 1.0);
    }
  `;

  const FRAGMENT_SHADER = `#version 300 es
    precision highp float;

    uniform float uTime;
    uniform float uSpeed;
    uniform float uSpecularIntensity;
    uniform vec3 uColorDeep;
    uniform vec3 uColorShallow;
    uniform vec3 uColorSpecular;
    uniform vec3 uColorSkyReflection;
    uniform vec3 uColorBackground;
    uniform vec3 uCameraPosition;
    uniform float uFadeWidth;
    uniform float uErosionStrength;

    in vec3 vWorldPosition;
    in vec3 vNormal;
    in vec2 vUv;

    out vec4 outColor;

    float hash21(vec2 point) {
      return fract(sin(dot(point, vec2(127.1, 311.7))) * 43758.5453123);
    }

    float valueNoise(vec2 point) {
      vec2 cell = floor(point);
      vec2 local = fract(point);
      vec2 curve = local * local * (3.0 - 2.0 * local);
      float bottom = mix(
        hash21(cell),
        hash21(cell + vec2(1.0, 0.0)),
        curve.x
      );
      float top = mix(
        hash21(cell + vec2(0.0, 1.0)),
        hash21(cell + vec2(1.0, 1.0)),
        curve.x
      );
      return mix(bottom, top, curve.y);
    }

    void main() {
      vec2 flowUvA = vUv * vec2(110.0, 22.0) +
        vec2(-uTime * uSpeed * 0.35, 0.0);
      vec2 flowUvB = vUv * vec2(170.0, 34.0) +
        vec2(-uTime * uSpeed * 0.55, sin(uTime * 0.15) * 0.08);

      float noiseA = valueNoise(flowUvA);
      float noiseB = valueNoise(flowUvB);
      vec3 rippleNormal = vec3(
        (noiseA - 0.5) * 0.25,
        (noiseB - 0.5) * 0.25,
        1.0
      );
      vec3 normal = normalize(vNormal + rippleNormal * 0.5);

      vec3 lightPosition = vec3(20.0, 65.0, 40.0);
      vec3 lightDirection = normalize(lightPosition - vWorldPosition);
      vec3 viewDirection = normalize(uCameraPosition - vWorldPosition);
      vec3 halfDirection = normalize(lightDirection + viewDirection);

      float cosineTheta = max(0.0, dot(normal, viewDirection));
      float fresnelBase = 0.02;
      float fresnel = fresnelBase +
        (1.0 - fresnelBase) * pow(1.0 - cosineTheta, 4.8);

      float deepFactor = smoothstep(0.0, 0.45, vUv.y) *
        (1.0 - smoothstep(0.55, 1.0, vUv.y));
      vec3 waterBaseColor = mix(uColorShallow, uColorDeep, deepFactor);

      float specular = pow(
        max(0.0, dot(normal, halfDirection)),
        140.0
      ) * uSpecularIntensity;
      vec3 specularColor = uColorSpecular * specular;

      vec3 skyReflection = mix(
        uColorDeep * 1.5,
        uColorSkyReflection,
        fresnel
      );
      vec3 finalColor = mix(
        waterBaseColor,
        skyReflection,
        fresnel * 0.8
      ) + specularColor;

      float erosionNoise = valueNoise(
        vUv * vec2(16.0, 4.0) +
        vec2(-uTime * uSpeed * 0.25, 0.0)
      );
      float dynamicOffset = (erosionNoise - 0.5) * uErosionStrength;
      float lowBound = clamp(uFadeWidth + dynamicOffset, 0.01, 0.49);
      float highBound = clamp(
        1.0 - (uFadeWidth + dynamicOffset),
        0.51,
        0.99
      );
      float lowerEdge = smoothstep(0.0, lowBound, vUv.y);
      float upperEdge = 1.0 - smoothstep(highBound, 1.0, vUv.y);
      float edgeFade = pow(lowerEdge * upperEdge, 1.4);

      vec3 fadedColor = mix(uColorBackground, finalColor, edgeFade);
      float alpha = 0.95 * edgeFade;
      outColor = vec4(fadedColor * alpha, alpha);
    }
  `;

  type Matrix4 = Float32Array;

  const createMatrix = (): Matrix4 => new Float32Array(16);

  const perspective = (
    output: Matrix4,
    fieldOfView: number,
    aspect: number,
    near: number,
    far: number
  ) => {
    const focalLength = 1 / Math.tan(fieldOfView / 2);
    const nearFar = 1 / (near - far);
    output.fill(0);
    output[0] = focalLength / aspect;
    output[5] = focalLength;
    output[10] = (far + near) * nearFar;
    output[11] = -1;
    output[14] = 2 * far * near * nearFar;
    return output;
  };

  const lookAt = (
    output: Matrix4,
    eye: ArrayLike<number>,
    target: ArrayLike<number>,
    up: ArrayLike<number>
  ) => {
    let z0 = eye[0] - target[0];
    let z1 = eye[1] - target[1];
    let z2 = eye[2] - target[2];
    let length = Math.hypot(z0, z1, z2) || 1;
    z0 /= length;
    z1 /= length;
    z2 /= length;

    let x0 = up[1] * z2 - up[2] * z1;
    let x1 = up[2] * z0 - up[0] * z2;
    let x2 = up[0] * z1 - up[1] * z0;
    length = Math.hypot(x0, x1, x2) || 1;
    x0 /= length;
    x1 /= length;
    x2 /= length;

    const y0 = z1 * x2 - z2 * x1;
    const y1 = z2 * x0 - z0 * x2;
    const y2 = z0 * x1 - z1 * x0;

    output[0] = x0;
    output[1] = y0;
    output[2] = z0;
    output[3] = 0;
    output[4] = x1;
    output[5] = y1;
    output[6] = z1;
    output[7] = 0;
    output[8] = x2;
    output[9] = y2;
    output[10] = z2;
    output[11] = 0;
    output[12] = -(x0 * eye[0] + x1 * eye[1] + x2 * eye[2]);
    output[13] = -(y0 * eye[0] + y1 * eye[1] + y2 * eye[2]);
    output[14] = -(z0 * eye[0] + z1 * eye[1] + z2 * eye[2]);
    output[15] = 1;
    return output;
  };

  class TimeRiverHero extends HTMLElement {
    private canvas: HTMLCanvasElement | null = null;
    private gl: WebGL2RenderingContext | null = null;
    private program: WebGLProgram | null = null;
    private vertexArray: WebGLVertexArrayObject | null = null;
    private buffers: WebGLBuffer[] = [];
    private indexCount = 0;
    private frameId = 0;
    private startedAt = performance.now();
    private lastFrameAt = 0;
    private visible = true;
    private lightTheme = false;
    private resizeObserver: ResizeObserver | null = null;
    private visibilityObserver: IntersectionObserver | null = null;
    private themeObserver: MutationObserver | null = null;
    private reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    );
    private projectionMatrix = createMatrix();
    private viewMatrix = createMatrix();
    private cameraPosition = new Float32Array(3);
    private trails: Trail[] = [];
    private trailCoordinates = new Float32Array(MAX_TRAILS * 4);
    private trailMotion = new Float32Array(MAX_TRAILS * 4);
    private previousPointer: PointerPosition | null = null;
    private touchStart: TouchStart | null = null;
    private uniforms: Record<string, WebGLUniformLocation | null> = {};

    connectedCallback() {
      this.canvas = this.querySelector("canvas");
      this.lightTheme =
        document.documentElement.getAttribute("data-theme") === "light";
      if (!this.canvas || !this.initialize()) return;

      document.addEventListener("visibilitychange", this.handleVisibility);
      this.addEventListener("pointermove", this.handlePointerMove, {
        passive: true,
      });
      this.addEventListener("pointerdown", this.handlePointerDown, {
        passive: true,
      });
      this.addEventListener("pointerup", this.handlePointerUp, {
        passive: true,
      });
      this.addEventListener("pointercancel", this.handlePointerCancel, {
        passive: true,
      });
      this.addEventListener("pointerenter", this.handlePointerEnter, {
        passive: true,
      });
      this.addEventListener("pointerleave", this.handlePointerLeave);
      this.resizeObserver = new ResizeObserver(this.resize);
      this.resizeObserver.observe(this);
      this.visibilityObserver = new IntersectionObserver(
        entries => {
          this.visible = entries[0]?.isIntersecting ?? false;
          if (this.visible) this.schedule();
        },
        { rootMargin: "120px" }
      );
      this.visibilityObserver.observe(this);
      this.themeObserver = new MutationObserver(this.handleThemeChange);
      this.themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });

      this.resize();
      this.canvas.classList.add("is-ready");
      if (this.reducedMotion.matches) this.draw(performance.now());
      else this.schedule();
    }

    disconnectedCallback() {
      if (this.frameId) cancelAnimationFrame(this.frameId);
      document.removeEventListener("visibilitychange", this.handleVisibility);
      this.removeEventListener("pointermove", this.handlePointerMove);
      this.removeEventListener("pointerdown", this.handlePointerDown);
      this.removeEventListener("pointerup", this.handlePointerUp);
      this.removeEventListener("pointercancel", this.handlePointerCancel);
      this.removeEventListener("pointerenter", this.handlePointerEnter);
      this.removeEventListener("pointerleave", this.handlePointerLeave);
      this.resizeObserver?.disconnect();
      this.visibilityObserver?.disconnect();
      this.themeObserver?.disconnect();
      if (this.gl && !this.gl.isContextLost()) {
        this.buffers.forEach(buffer => this.gl?.deleteBuffer(buffer));
        if (this.program) this.gl.deleteProgram(this.program);
        if (this.vertexArray) this.gl.deleteVertexArray(this.vertexArray);
      }
    }

    private createShader(type: number, source: string) {
      if (!this.gl) return null;
      const shader = this.gl.createShader(type);
      if (!shader) return null;
      this.gl.shaderSource(shader, source);
      this.gl.compileShader(shader);
      if (!this.gl.getShaderParameter(shader, this.gl.COMPILE_STATUS)) {
        this.gl.deleteShader(shader);
        return null;
      }
      return shader;
    }

    private initialize() {
      if (!this.canvas) return false;
      this.gl = this.canvas.getContext("webgl2", {
        alpha: true,
        antialias: true,
        depth: true,
        stencil: false,
        powerPreference: "high-performance",
      });
      if (!this.gl) return false;

      const vertexShader = this.createShader(
        this.gl.VERTEX_SHADER,
        VERTEX_SHADER
      );
      const fragmentShader = this.createShader(
        this.gl.FRAGMENT_SHADER,
        FRAGMENT_SHADER
      );
      if (!vertexShader || !fragmentShader) return false;

      this.program = this.gl.createProgram();
      this.vertexArray = this.gl.createVertexArray();
      if (!this.program || !this.vertexArray) return false;
      this.gl.attachShader(this.program, vertexShader);
      this.gl.attachShader(this.program, fragmentShader);
      this.gl.linkProgram(this.program);
      this.gl.deleteShader(vertexShader);
      this.gl.deleteShader(fragmentShader);
      if (!this.gl.getProgramParameter(this.program, this.gl.LINK_STATUS)) {
        return false;
      }

      const names = [
        "uProjectionMatrix",
        "uViewMatrix",
        "uTime",
        "uSpeed",
        "uTurbulence",
        "uFadeWidth",
        "uSpecularIntensity",
        "uColorDeep",
        "uColorShallow",
        "uColorSpecular",
        "uColorSkyReflection",
        "uColorBackground",
        "uCameraPosition",
        "uErosionStrength",
        "uSurfaceSize",
        "uRippleRadius",
        "uTrailCount",
      ];
      names.forEach(name => {
        this.uniforms[name] =
          this.gl?.getUniformLocation(this.program!, name) ?? null;
      });
      this.uniforms.uTrails = this.gl.getUniformLocation(
        this.program,
        "uTrails[0]"
      );
      this.uniforms.uTrailMotion = this.gl.getUniformLocation(
        this.program,
        "uTrailMotion[0]"
      );
      if (Object.values(this.uniforms).some(location => location === null)) {
        return false;
      }

      if (!this.setupMesh()) return false;

      this.gl.enable(this.gl.DEPTH_TEST);
      this.gl.depthFunc(this.gl.LEQUAL);
      this.gl.enable(this.gl.BLEND);
      this.gl.blendFunc(this.gl.SRC_ALPHA, this.gl.ONE_MINUS_SRC_ALPHA);
      this.gl.clearColor(0, 0, 0, 0);
      return true;
    }

    private setupMesh() {
      if (!this.gl || !this.program || !this.vertexArray) return false;

      const width = 240;
      const depth = RIVER_DEPTH;
      const segmentsX = 250;
      const segmentsZ = 45;
      const positions: number[] = [];
      const uvs: number[] = [];
      const indices: number[] = [];

      for (let zIndex = 0; zIndex <= segmentsZ; zIndex++) {
        const v = zIndex / segmentsZ;
        const z = (v - 0.5) * depth;
        for (let xIndex = 0; xIndex <= segmentsX; xIndex++) {
          const u = xIndex / segmentsX;
          positions.push((u - 0.5) * width, z);
          uvs.push(u, v);
        }
      }

      for (let zIndex = 0; zIndex < segmentsZ; zIndex++) {
        for (let xIndex = 0; xIndex < segmentsX; xIndex++) {
          const firstRow = zIndex * (segmentsX + 1);
          const secondRow = (zIndex + 1) * (segmentsX + 1);
          indices.push(
            firstRow + xIndex,
            firstRow + xIndex + 1,
            secondRow + xIndex,
            firstRow + xIndex + 1,
            secondRow + xIndex + 1,
            secondRow + xIndex
          );
        }
      }

      const positionBuffer = this.gl.createBuffer();
      const uvBuffer = this.gl.createBuffer();
      const indexBuffer = this.gl.createBuffer();
      if (!positionBuffer || !uvBuffer || !indexBuffer) return false;
      this.buffers.push(positionBuffer, uvBuffer, indexBuffer);
      this.indexCount = indices.length;

      this.gl.bindVertexArray(this.vertexArray);

      const positionLocation = this.gl.getAttribLocation(
        this.program,
        "aPosition"
      );
      const uvLocation = this.gl.getAttribLocation(this.program, "aUv");
      if (positionLocation < 0 || uvLocation < 0) return false;

      this.gl.bindBuffer(this.gl.ARRAY_BUFFER, positionBuffer);
      this.gl.bufferData(
        this.gl.ARRAY_BUFFER,
        new Float32Array(positions),
        this.gl.STATIC_DRAW
      );
      this.gl.enableVertexAttribArray(positionLocation);
      this.gl.vertexAttribPointer(
        positionLocation,
        2,
        this.gl.FLOAT,
        false,
        0,
        0
      );

      this.gl.bindBuffer(this.gl.ARRAY_BUFFER, uvBuffer);
      this.gl.bufferData(
        this.gl.ARRAY_BUFFER,
        new Float32Array(uvs),
        this.gl.STATIC_DRAW
      );
      this.gl.enableVertexAttribArray(uvLocation);
      this.gl.vertexAttribPointer(uvLocation, 2, this.gl.FLOAT, false, 0, 0);

      this.gl.bindBuffer(this.gl.ELEMENT_ARRAY_BUFFER, indexBuffer);
      this.gl.bufferData(
        this.gl.ELEMENT_ARRAY_BUFFER,
        new Uint16Array(indices),
        this.gl.STATIC_DRAW
      );
      this.gl.bindVertexArray(null);
      return true;
    }

    private resize = () => {
      if (!this.canvas || !this.gl) return;
      const bounds = this.getBoundingClientRect();
      const pixelRatio = Math.min(window.devicePixelRatio || 1, 1.5);
      const width = Math.max(1, Math.round(bounds.width * pixelRatio));
      const height = Math.max(1, Math.round(bounds.height * pixelRatio));
      if (this.canvas.width === width && this.canvas.height === height) return;
      this.canvas.width = width;
      this.canvas.height = height;
      this.gl.viewport(0, 0, width, height);
      this.draw(performance.now());
    };

    private updateCamera() {
      if (!this.canvas) return;
      const radius = 52;
      const theta = 0;
      const phi = Math.PI / 4.8;
      const eyeX = radius * Math.sin(phi) * Math.sin(theta);
      const eyeY = radius * Math.cos(phi);
      const eyeZ = radius * Math.sin(phi) * Math.cos(theta);
      this.cameraPosition.set([eyeX, eyeY, eyeZ]);
      lookAt(this.viewMatrix, this.cameraPosition, [0, -7, 0], [0, 1, 0]);
      perspective(
        this.projectionMatrix,
        (55 * Math.PI) / 180,
        16 / 9,
        0.1,
        1000
      );
    }

    private uploadTrails(now: number) {
      if (!this.gl || !this.canvas) return;

      while (
        this.trails.length &&
        now - this.trails[0].createdAt > TRAIL_LIFETIME
      ) {
        this.trails.shift();
      }

      this.trailCoordinates.fill(0);
      this.trailMotion.fill(0);
      this.trails.forEach((trail, index) => {
        const offset = index * 4;
        this.trailCoordinates[offset] = trail.fromX;
        this.trailCoordinates[offset + 1] = trail.fromY;
        this.trailCoordinates[offset + 2] = trail.x;
        this.trailCoordinates[offset + 3] = trail.y;
        this.trailMotion[offset] = trail.deltaX;
        this.trailMotion[offset + 1] = trail.deltaY;
        this.trailMotion[offset + 2] =
          (trail.createdAt - this.startedAt) / 1000;
        this.trailMotion[offset + 3] = trail.speed;
      });

      const bounds = this.canvas.getBoundingClientRect();
      this.gl.uniform2f(
        this.uniforms.uSurfaceSize,
        bounds.width,
        bounds.height
      );
      this.gl.uniform1f(
        this.uniforms.uRippleRadius,
        clamp(bounds.width * 0.13, 58, 96)
      );
      this.gl.uniform1i(this.uniforms.uTrailCount, this.trails.length);
      this.gl.uniform4fv(this.uniforms.uTrails, this.trailCoordinates);
      this.gl.uniform4fv(this.uniforms.uTrailMotion, this.trailMotion);
    }

    private draw = (now: number) => {
      if (
        !this.gl ||
        !this.program ||
        !this.vertexArray ||
        !this.canvas ||
        !this.indexCount
      ) {
        return;
      }

      this.updateCamera();
      this.gl.viewport(0, 0, this.canvas.width, this.canvas.height);
      this.gl.clear(this.gl.COLOR_BUFFER_BIT | this.gl.DEPTH_BUFFER_BIT);
      this.gl.useProgram(this.program);
      this.gl.bindVertexArray(this.vertexArray);

      this.gl.uniformMatrix4fv(
        this.uniforms.uProjectionMatrix,
        false,
        this.projectionMatrix
      );
      this.gl.uniformMatrix4fv(
        this.uniforms.uViewMatrix,
        false,
        this.viewMatrix
      );
      this.gl.uniform1f(this.uniforms.uTime, (now - this.startedAt) / 1000);
      this.gl.uniform1f(this.uniforms.uSpeed, FLOW_SPEED);
      this.gl.uniform1f(
        this.uniforms.uTurbulence,
        this.lightTheme ? TURBULENCE_LIGHT : TURBULENCE_DARK
      );
      this.gl.uniform1f(this.uniforms.uFadeWidth, FADE_WIDTH);
      this.gl.uniform1f(
        this.uniforms.uSpecularIntensity,
        this.lightTheme ? SPECULAR_INTENSITY_LIGHT : SPECULAR_INTENSITY
      );
      this.gl.uniform1f(this.uniforms.uErosionStrength, EROSION_STRENGTH);
      this.gl.uniform3fv(
        this.uniforms.uColorDeep,
        this.lightTheme ? WATER_DEEP_LIGHT : WATER_DEEP_DARK
      );
      this.gl.uniform3fv(
        this.uniforms.uColorShallow,
        this.lightTheme ? WATER_SHALLOW_LIGHT : WATER_SHALLOW_DARK
      );
      this.gl.uniform3fv(
        this.uniforms.uColorSpecular,
        this.lightTheme ? WATER_SPECULAR_LIGHT : WATER_SPECULAR_DARK
      );
      this.gl.uniform3fv(
        this.uniforms.uColorSkyReflection,
        this.lightTheme ? WATER_SKY_LIGHT : WATER_SKY_DARK
      );
      this.gl.uniform3fv(
        this.uniforms.uColorBackground,
        this.lightTheme ? BACKGROUND_LIGHT : BACKGROUND_DARK
      );
      this.gl.uniform3fv(this.uniforms.uCameraPosition, this.cameraPosition);
      this.uploadTrails(now);

      this.gl.drawElements(
        this.gl.TRIANGLES,
        this.indexCount,
        this.gl.UNSIGNED_SHORT,
        0
      );
      this.gl.bindVertexArray(null);
    };

    private getPointerPosition(event: PointerEvent) {
      if (!this.canvas) return null;
      const bounds = this.canvas.getBoundingClientRect();
      if (bounds.width <= 0 || bounds.height <= 0) return null;
      return {
        x: event.clientX - bounds.left,
        y: event.clientY - bounds.top,
      };
    }

    private addTrail(
      from: PointerPosition,
      position: { x: number; y: number },
      now: number
    ) {
      const deltaX = position.x - from.x;
      const deltaY = position.y - from.y;
      const distance = Math.hypot(deltaX, deltaY);
      if (distance < 0.8) return false;

      const sampleDuration = now - from.time;
      if (
        sampleDuration < TRAIL_SAMPLE_INTERVAL &&
        distance < TRAIL_FORCE_DISTANCE
      ) {
        return false;
      }

      const frameDuration = Math.max(4, sampleDuration);
      this.trails.push({
        fromX: from.x,
        fromY: from.y,
        x: position.x,
        y: position.y,
        deltaX,
        deltaY,
        createdAt: now,
        speed: clamp(distance / (frameDuration / 16.667), 0, 20),
      });
      if (this.trails.length > MAX_TRAILS) this.trails.shift();
      return true;
    }

    private handlePointerMove = (event: PointerEvent) => {
      if (this.reducedMotion.matches) return;
      if (event.pointerType === "touch") {
        if (
          this.touchStart?.pointerId === event.pointerId &&
          Math.hypot(
            event.clientX - this.touchStart.x,
            event.clientY - this.touchStart.y
          ) > TOUCH_TAP_MAX_DISTANCE
        ) {
          this.touchStart = null;
        }
        return;
      }

      const position = this.getPointerPosition(event);
      if (!position) return;
      const now = performance.now();
      if (!this.previousPointer) {
        this.previousPointer = { ...position, time: now };
        return;
      }

      if (this.addTrail(this.previousPointer, position, now)) {
        this.previousPointer = { ...position, time: now };
        this.schedule();
      }
    };

    private handlePointerDown = (event: PointerEvent) => {
      if (event.pointerType !== "touch" || this.reducedMotion.matches) return;
      this.touchStart = {
        x: event.clientX,
        y: event.clientY,
        time: performance.now(),
        pointerId: event.pointerId,
      };
    };

    private handlePointerUp = (event: PointerEvent) => {
      if (event.pointerType !== "touch" || !this.touchStart) return;
      const start = this.touchStart;
      this.touchStart = null;
      const now = performance.now();
      if (
        event.pointerId !== start.pointerId ||
        now - start.time > TOUCH_TAP_MAX_DURATION ||
        Math.hypot(event.clientX - start.x, event.clientY - start.y) >
          TOUCH_TAP_MAX_DISTANCE
      ) {
        return;
      }

      const position = this.getPointerPosition(event);
      if (!position) return;
      const halfSegment = 0.75;
      this.trails.push({
        fromX: position.x - halfSegment,
        fromY: position.y,
        x: position.x + halfSegment,
        y: position.y,
        deltaX: halfSegment * 2,
        deltaY: 0,
        createdAt: now,
        speed: 8,
      });
      if (this.trails.length > MAX_TRAILS) this.trails.shift();
      this.schedule();
    };

    private handlePointerCancel = (event: PointerEvent) => {
      if (this.touchStart?.pointerId === event.pointerId) {
        this.touchStart = null;
      }
    };

    private handlePointerEnter = (event: PointerEvent) => {
      if (event.pointerType === "touch" || this.reducedMotion.matches) return;
      const position = this.getPointerPosition(event);
      if (!position) return;
      this.previousPointer = { ...position, time: performance.now() };
    };

    private handlePointerLeave = () => {
      this.previousPointer = null;
    };

    private handleVisibility = () => {
      if (!document.hidden) this.schedule();
    };

    private handleThemeChange = () => {
      const lightTheme =
        document.documentElement.getAttribute("data-theme") === "light";
      if (this.lightTheme === lightTheme) return;
      this.lightTheme = lightTheme;
      this.draw(performance.now());
    };

    private schedule = () => {
      if (
        this.frameId ||
        !this.visible ||
        document.hidden ||
        this.reducedMotion.matches
      ) {
        return;
      }
      this.frameId = requestAnimationFrame(this.tick);
    };

    private tick = (now: number) => {
      this.frameId = 0;
      if (now - this.lastFrameAt >= 32) {
        this.lastFrameAt = now;
        this.draw(now);
      }
      this.schedule();
    };
  }

  if (!customElements.get("time-river-hero")) {
    customElements.define("time-river-hero", TimeRiverHero);
  }
</script>
