---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import FootprintTimeline from "@/components/FootprintTimeline";
import { SITE } from "@/config";
import { FOOTPRINT_TIMELINE_PAGE_SIZE } from "@/utils/footprintRecords";
import "leaflet/dist/leaflet.css";
import "leaflet.markercluster/dist/MarkerCluster.css";
import "lightgallery/css/lightgallery.css";
import "lightgallery/css/lg-zoom.css";
import "lightgallery/css/lg-thumbnail.css";

const sourceEntries = await getCollection(
  "footprints",
  ({ data }) => !data.draft && data.photos.some(photo => !photo.hidden)
);

const sortedEntries = sourceEntries.sort(
  (a, b) => b.data.visitedAt.getTime() - a.data.visitedAt.getTime()
);
const totalCities = new Set(
  sortedEntries.map(
    entry => `${entry.data.country}/${entry.data.region}/${entry.data.city}`
  )
).size;

type MapLocation = {
  id: string;
  visitedAt: string;
  coordinates: { lat: number; lng: number };
  placeGroup: number;
  cover: string;
  photoCount: number;
};

const getMapCoverPosition = (position?: string) => {
  const keywords = position?.trim().toLowerCase().split(/\s+/) || [];
  const horizontal = keywords.find(keyword =>
    ["left", "right"].includes(keyword)
  );
  const vertical = keywords.find(keyword =>
    ["top", "bottom"].includes(keyword)
  );

  return [horizontal, vertical].filter(Boolean).join(" ") || "center";
};

const placeGroups = new Map<string, number>();
const locations: MapLocation[] = await Promise.all(
  sortedEntries.map(async entry => {
    const visiblePhotos = entry.data.photos.filter(photo => !photo.hidden);
    const placeKey = `${entry.data.country}/${entry.data.region}/${entry.data.city}/${entry.data.place}`;
    if (!placeGroups.has(placeKey)) {
      placeGroups.set(placeKey, placeGroups.size);
    }

    const mapCover = await getImage({
      src: visiblePhotos[0].src,
      width: 80,
      height: 80,
      fit: "cover",
      position: getMapCoverPosition(visiblePhotos[0].position),
      format: "webp",
      quality: 68,
    });

    return {
      id: entry.id.replace(/\.(md|mdx)$/, ""),
      visitedAt: entry.data.visitedAt.toISOString(),
      coordinates: entry.data.coordinates,
      placeGroup: placeGroups.get(placeKey)!,
      cover: mapCover.src,
      photoCount: visiblePhotos.length,
    };
  })
);
const mapData = JSON.stringify(locations).replace(/</g, "\\u003c");
---

<Layout
  title={`足迹 | ${SITE.title}`}
  description="用地图与照片记录抵达过的地方。"
>
  <Header />
  <Breadcrumb />

  <main
    id="main-content"
    class="footprints-page mx-auto mt-4 w-full max-w-app px-4 pb-12"
  >
    <header class="footprints-overview">
      <div>
        <h1 class="text-2xl font-semibold sm:text-3xl">
          <span>{totalCities}</span> 个城市 ·
          <span>{locations.length}</span> 个足迹
        </h1>
      </div>
      <p class="footprints-tagline">地图标记去向，照片留下当时的光。</p>
    </header>

    <div class="footprints-view-toolbar" data-pinned="false">
      <div
        class="footprints-view-switch diary-filter-options"
        role="tablist"
        aria-label="足迹展示方式"
      >
        <span
          id="footprints-view-active-indicator"
          class="diary-filter-active-indicator"
          aria-hidden="true"></span>
        <button
          id="footprints-map-tab"
          type="button"
          role="tab"
          aria-selected="true"
          aria-controls="footprints-map-view"
          data-footprints-view="map"
        >
          地图
        </button>
        <button
          id="footprints-timeline-tab"
          type="button"
          role="tab"
          aria-selected="false"
          aria-controls="footprints-timeline"
          data-footprints-view="timeline"
          tabindex="-1"
        >
          时间线
        </button>
      </div>
    </div>

    <section
      id="footprints-map-view"
      class="footprints-map-shell footprints-view-panel"
      role="tabpanel"
      aria-labelledby="footprints-map-tab"
    >
      <h2 id="footprints-map-heading" class="sr-only">照片足迹地图</h2>
      <div
        id="footprints-map"
        class="footprints-map"
        role="region"
        aria-label="可缩放的照片足迹地图，点击照片标记筛选下方记录"
      >
      </div>

      <aside
        id="footprint-journal"
        class="footprint-results-panel"
        aria-labelledby="journal-heading"
        aria-hidden="true"
        data-state="closed"
        inert
      >
        <header class="footprint-results-header">
          <h2 id="journal-heading">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3" y="5" width="15" height="14" rx="2"></rect>
              <path d="m7 14 2.5-2.5 2.2 2.2 1.5-1.5L18 17"></path>
              <path d="M7 3h14v14"></path>
            </svg>
            <span id="journal-heading-text">当前标记</span>
          </h2>

          <div class="footprint-results-actions">
            <button
              id="footprints-panel-expand"
              type="button"
              aria-label="展开照片面板"
              aria-expanded="false"
              title="展开照片面板"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m6 15 6-6 6 6"></path>
              </svg>
            </button>
            <button
              id="footprints-panel-close"
              type="button"
              aria-label="关闭照片面板"
              title="关闭照片面板"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m6 6 12 12M18 6 6 18"></path>
              </svg>
            </button>
          </div>
        </header>

        <div id="footprints-results-body" class="footprint-results-body">
          <div id="footprint-gallery" aria-live="polite"></div>

          <p id="footprints-empty" class="footprints-empty">
            正在加载照片记录…
          </p>

          <button id="footprints-load-more" type="button" hidden>
            加载更多
          </button>
        </div>
      </aside>
    </section>

    <section
      id="footprints-timeline"
      class="footprints-timeline footprints-view-panel"
      role="tabpanel"
      aria-labelledby="footprints-timeline-tab"
      hidden
    >
      <FootprintTimeline
        client:visible
        totalItems={locations.length}
        pageSize={FOOTPRINT_TIMELINE_PAGE_SIZE}
        timezone={SITE.timezone}
      />
    </section>
  </main>

  <Footer />

  <script
    is:inline
    id="footprints-map-data"
    type="application/json"
    data-timezone={SITE.timezone}
    set:html={mapData}
  />
</Layout>

<script>
  import L from "leaflet";
  import "leaflet.markercluster";

  type LocationData = {
    id: string;
    visitedAt: string;
    coordinates: { lat: number; lng: number };
    placeGroup: number;
    cover: string;
    photoCount: number;
  };

  type FootprintPhoto = {
    thumbnail: string;
    original: string;
    width: number;
    height: number;
    alt: string;
    caption?: string;
    position?: string;
  };

  type FootprintRecord = {
    id: string;
    visitedAt: string;
    country: string;
    city: string;
    place: string;
    region: string;
    note: string;
    photos: FootprintPhoto[];
    relatedPosts: Array<{
      id: string;
      title: string;
      href: string;
    }>;
  };

  const initializeFootprints = async () => {
    const mapElement = document.querySelector<HTMLElement>("#footprints-map");
    const dataElement = document.querySelector<HTMLScriptElement>(
      "#footprints-map-data"
    );

    if (
      !mapElement ||
      !dataElement ||
      mapElement.dataset.initialized === "true"
    ) {
      return;
    }

    mapElement.dataset.initialized = "true";
    const locations = JSON.parse(
      dataElement.textContent || "[]"
    ) as LocationData[];
    const map = L.map(mapElement, {
      zoomControl: false,
      scrollWheelZoom: true,
      // 允许 fitBounds 使用小数缩放级别，避免整数级别之间产生过大留白。
      zoomSnap: 0.25,
      zoomDelta: 1,
      wheelPxPerZoomLevel: 40,
      attributionControl: true,
    });
    const mapZoomControl = L.control
      .zoom({ position: "bottomleft" })
      .addTo(map);
    map.attributionControl.setPrefix(false);

    const pointPane = map.createPane("footprint-point-pane");
    const clusterPane = map.createPane("footprint-cluster-pane");
    pointPane.style.zIndex = "610";
    clusterPane.style.zIndex = "620";

    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    }).addTo(map);

    const timezone = dataElement.dataset.timezone || "Asia/Shanghai";
    const gallery = document.querySelector<HTMLElement>("#footprint-gallery");
    const empty = document.querySelector<HTMLElement>("#footprints-empty");
    const loadMoreButton = document.querySelector<HTMLButtonElement>(
      "#footprints-load-more"
    );
    const heading = document.querySelector<HTMLElement>(
      "#journal-heading-text"
    );
    const panel = document.querySelector<HTMLElement>("#footprint-journal");
    const panelBody = document.querySelector<HTMLElement>(
      "#footprints-results-body"
    );
    const panelExpandButton = document.querySelector<HTMLButtonElement>(
      "#footprints-panel-expand"
    );
    const panelCloseButton = document.querySelector<HTMLButtonElement>(
      "#footprints-panel-close"
    );
    const mapShell = mapElement.closest<HTMLElement>(".footprints-map-shell");
    const timelinePanel = document.querySelector<HTMLElement>(
      "#footprints-timeline"
    );
    const viewTabs = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-footprints-view]")
    );
    const viewIndicator = document.querySelector<HTMLElement>(
      "#footprints-view-active-indicator"
    );
    const viewToolbar = document.querySelector<HTMLElement>(
      ".footprints-view-toolbar"
    );
    if (
      !gallery ||
      !empty ||
      !loadMoreButton ||
      !heading ||
      !panel ||
      !panelBody ||
      !panelExpandButton ||
      !panelCloseButton ||
      !mapShell ||
      !timelinePanel ||
      !viewIndicator ||
      !viewToolbar ||
      viewTabs.length !== 2
    ) {
      return;
    }

    let toolbarPinnedFrame: number | null = null;
    const updateToolbarPinnedState = () => {
      toolbarPinnedFrame = null;
      const stickyTop = Number.parseFloat(getComputedStyle(viewToolbar).top);
      viewToolbar.dataset.pinned = String(
        viewToolbar.getBoundingClientRect().top <= stickyTop + 1
      );
    };
    const scheduleToolbarPinnedUpdate = () => {
      if (toolbarPinnedFrame !== null) return;
      toolbarPinnedFrame = requestAnimationFrame(updateToolbarPinnedState);
    };
    updateToolbarPinnedState();
    window.addEventListener("scroll", scheduleToolbarPinnedUpdate, {
      passive: true,
    });
    window.addEventListener("resize", scheduleToolbarPinnedUpdate);

    const isLightGalleryTarget = (target: EventTarget | null) =>
      target instanceof Element && target.closest(".lg-outer");
    const blockSecondaryGalleryDrag = (event: MouseEvent) => {
      if (event.button === 0 || !isLightGalleryTarget(event.target)) return;
      // lightGallery 2.9 beta treats every mouse button as a drag start.
      // Keep the native context menu, but do not let a right press enter its
      // internal dragging state.
      event.stopPropagation();
    };
    const releaseGalleryDragAfterContextMenu = (event: MouseEvent) => {
      const outer = isLightGalleryTarget(event.target);
      if (!(outer instanceof HTMLElement)) return;
      window.setTimeout(() => {
        window.dispatchEvent(
          new MouseEvent("mouseup", {
            bubbles: true,
            button: 2,
            clientX: event.clientX,
            clientY: event.clientY,
          })
        );
        outer.classList.remove("lg-grabbing", "lg-dragging", "lg-hide-items");
        outer.classList.add("lg-grab", "lg-components-open");
        outer
          .closest(".lg-container")
          ?.classList.remove("lg-dragging-vertical");
      }, 0);
    };
    document.addEventListener("mousedown", blockSecondaryGalleryDrag, true);
    document.addEventListener(
      "contextmenu",
      releaseGalleryDragAfterContextMenu,
      true
    );

    const dayFormatter = new Intl.DateTimeFormat("en-US", {
      day: "2-digit",
      timeZone: timezone,
    });
    const monthFormatter = new Intl.DateTimeFormat("en-US", {
      month: "2-digit",
      timeZone: timezone,
    });
    const yearFormatter = new Intl.DateTimeFormat("en-US", {
      year: "numeric",
      timeZone: timezone,
    });
    const weekdayFormatter = new Intl.DateTimeFormat("zh-CN", {
      weekday: "short",
      timeZone: timezone,
    });
    const locationById = new Map(
      locations.map((location, index) => [location.id, { ...location, index }])
    );
    const SAME_LOCATION_RADIUS_METERS = 30;
    const MAX_CLUSTER_PLACE_COUNT_TO_LOAD = 3;
    const distanceBetween = (
      from: { lat: number; lng: number },
      to: { lat: number; lng: number }
    ) => {
      const toRadians = (degrees: number) => (degrees * Math.PI) / 180;
      const latitudeDelta = toRadians(to.lat - from.lat);
      const longitudeDelta = toRadians(to.lng - from.lng);
      const fromLatitude = toRadians(from.lat);
      const toLatitude = toRadians(to.lat);
      const haversine =
        Math.sin(latitudeDelta / 2) ** 2 +
        Math.cos(fromLatitude) *
          Math.cos(toLatitude) *
          Math.sin(longitudeDelta / 2) ** 2;

      return (
        6371008.8 *
        2 *
        Math.atan2(Math.sqrt(haversine), Math.sqrt(1 - haversine))
      );
    };
    const shareLocation = (locationIds: string[]) => {
      if (locationIds.length < 2) return false;

      const groupedLocations = locationIds.map(id => locationById.get(id));
      const validLocations = groupedLocations.filter(
        (location): location is NonNullable<typeof location> =>
          Boolean(location)
      );
      const first = validLocations[0];
      if (!first || validLocations.length !== locationIds.length) return false;
      if (
        validLocations.some(
          location => location.placeGroup !== first.placeGroup
        )
      ) {
        return false;
      }

      return validLocations.every((location, index) =>
        validLocations
          .slice(index + 1)
          .every(
            otherLocation =>
              distanceBetween(
                location.coordinates,
                otherLocation.coordinates
              ) <= SAME_LOCATION_RADIUS_METERS
          )
      );
    };

    const markers = new Map<string, L.Marker>();
    const MARKER_CLUSTER_RADIUS = 50;
    const markerVisualData = new WeakMap<
      L.Marker,
      { id: string; cover: string; photoCount: number }
    >();
    const createPhotoMarkerContent = (
      cover: string,
      photoCount: number,
      label?: string
    ) => {
      const markerContent = document.createElement("div");
      markerContent.className = "photo-map-marker";
      if (label) {
        markerContent.setAttribute("aria-label", label);
      } else {
        markerContent.setAttribute("aria-hidden", "true");
      }

      const image = document.createElement("img");
      image.src = cover;
      image.alt = "";
      image.loading = "eager";
      image.decoding = "sync";

      const badge = document.createElement("span");
      badge.textContent = String(photoCount);

      markerContent.append(image, badge);
      return markerContent;
    };
    const markerClusters = L.markerClusterGroup({
      showCoverageOnHover: false,
      zoomToBoundsOnClick: false,
      spiderfyOnMaxZoom: false,
      clusterPane: "footprint-cluster-pane",
      // 覆盖照片、数量徽标和选中态的实际占位，避免相邻标记视觉重叠。
      maxClusterRadius: MARKER_CLUSTER_RADIUS,
      iconCreateFunction: cluster => {
        const children = cluster.getAllChildMarkers();
        const photoCount = children.reduce(
          (total, marker) =>
            total + (markerVisualData.get(marker)?.photoCount ?? 0),
          0
        );
        const cover =
          children
            .map(marker => markerVisualData.get(marker))
            .filter(
              (
                visual
              ): visual is { id: string; cover: string; photoCount: number } =>
                Boolean(visual)
            )
            .sort(
              (a, b) =>
                (locationById.get(a.id)?.index ?? Number.MAX_SAFE_INTEGER) -
                (locationById.get(b.id)?.index ?? Number.MAX_SAFE_INTEGER)
            )[0]?.cover ?? "";

        return L.divIcon({
          className: "footprint-map-icon",
          html: createPhotoMarkerContent(
            cover,
            photoCount,
            `${photoCount} 张照片`
          ),
          iconSize: [44, 51],
          iconAnchor: [22, 50],
        });
      },
    }).addTo(map);
    const bounds: [number, number][] = [];

    type GalleryInstance = {
      refresh: () => void;
      destroy: () => number;
    };

    const PAGE_SIZE = 20;
    let activeIds: string[] = [];
    let loadedCount = 0;
    let selectionVersion = 0;
    let isLoading = false;
    let galleryInstances: GalleryInstance[] = [];
    let isPhotoGalleryOpen = false;
    type PanelState = "closed" | "half" | "expanded";
    let panelState: PanelState = "closed";
    const mobilePanelQuery = window.matchMedia("(max-width: 768px)");

    const updateMapViewportHeight = () => {
      const viewportHeight = window.innerHeight;
      const mapTop = mapShell.getBoundingClientRect().top + window.scrollY;
      const bottomGap = mobilePanelQuery.matches ? 20 : 30;
      const availableHeight = Math.max(
        0,
        Math.floor(viewportHeight - mapTop - bottomGap)
      );
      const aspectRatioHeight = Math.floor((mapShell.clientWidth * 4) / 5);
      const mapHeight = mobilePanelQuery.matches
        ? availableHeight
        : Math.min(availableHeight, aspectRatioHeight);

      mapShell.style.setProperty("--footprints-map-height", `${mapHeight}px`);
      requestAnimationFrame(() => map.invalidateSize({ pan: false }));
    };

    const setPanelState = (state: PanelState) => {
      panelState =
        !mobilePanelQuery.matches && state === "expanded" ? "half" : state;
      const isOpen = panelState !== "closed";
      const isExpanded = panelState === "expanded";

      panel.dataset.state = panelState;
      panel.setAttribute("aria-hidden", String(!isOpen));
      panel.toggleAttribute("inert", !isOpen);
      mapShell.classList.toggle("is-panel-open", isOpen);
      mapShell.classList.toggle("is-panel-expanded", isExpanded);
      panelExpandButton.setAttribute("aria-expanded", String(isExpanded));
      panelExpandButton.setAttribute(
        "aria-label",
        isExpanded ? "还原照片面板" : "展开照片面板"
      );
      panelExpandButton.title = isExpanded ? "还原照片面板" : "展开照片面板";
    };

    const getPanelAwarePadding = () => {
      const paddingTopLeft: L.PointTuple = [56, 72];
      let right = 56;
      let bottom = 52;

      if (panelState !== "closed") {
        if (mobilePanelQuery.matches) {
          bottom += panel.offsetHeight + 12;
        } else {
          right += panel.offsetWidth + 12;
        }
      }

      right = Math.min(
        right,
        Math.max(56, mapElement.clientWidth - paddingTopLeft[0] - 96)
      );
      bottom = Math.min(
        bottom,
        Math.max(52, mapElement.clientHeight - paddingTopLeft[1] - 80)
      );

      return {
        paddingTopLeft,
        paddingBottomRight: [right, bottom] as L.PointTuple,
      };
    };

    const moveToPanelAwareCenter = (
      center: L.LatLngExpression,
      targetZoom: number
    ) => {
      const { paddingTopLeft, paddingBottomRight } = getPanelAwarePadding();
      const paddingOffset = L.point(paddingBottomRight)
        .subtract(L.point(paddingTopLeft))
        .divideBy(2);
      const targetCenter = map.unproject(
        map.project(center, targetZoom).add(paddingOffset),
        targetZoom
      );

      if (Math.abs(map.getZoom() - targetZoom) < 0.001) {
        map.panTo(targetCenter, { animate: true, duration: 0.65 });
      } else {
        map.flyTo(targetCenter, targetZoom, { duration: 0.65 });
      }
    };

    const overview = document.querySelector<HTMLElement>(
      ".footprints-overview"
    );
    const overviewResizeObserver = new ResizeObserver(updateMapViewportHeight);
    if (overview) overviewResizeObserver.observe(overview);
    updateMapViewportHeight();
    window.addEventListener("resize", updateMapViewportHeight);
    mobilePanelQuery.addEventListener("change", () => {
      updateMapViewportHeight();
      if (!mobilePanelQuery.matches && panelState === "expanded") {
        setPanelState("half");
      }
    });

    const createPinIcon = () => {
      const icon = document.createElementNS(
        "http://www.w3.org/2000/svg",
        "svg"
      );
      icon.setAttribute("viewBox", "0 0 24 24");
      icon.setAttribute("aria-hidden", "true");

      const pin = document.createElementNS(
        "http://www.w3.org/2000/svg",
        "path"
      );
      pin.setAttribute("d", "M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z");
      const center = document.createElementNS(
        "http://www.w3.org/2000/svg",
        "circle"
      );
      center.setAttribute("cx", "12");
      center.setAttribute("cy", "10");
      center.setAttribute("r", "2.5");
      icon.append(pin, center);
      return icon;
    };

    const createRelatedIcon = (kind: "article" | "arrow" | "chevron") => {
      const icon = document.createElementNS(
        "http://www.w3.org/2000/svg",
        "svg"
      );
      icon.setAttribute("viewBox", "0 0 24 24");
      icon.setAttribute("aria-hidden", "true");

      const path = document.createElementNS(
        "http://www.w3.org/2000/svg",
        "path"
      );
      path.setAttribute(
        "d",
        kind === "article"
          ? "M6 3h8l4 4v14H6z M14 3v5h4 M9 13h6 M9 17h5"
          : kind === "arrow"
            ? "M7 17 17 7 M8 7h9v9"
            : "M8 10l4 4 4-4"
      );
      icon.append(path);
      return icon;
    };

    const escapeHTML = (value: string) =>
      value.replace(
        /[&<>"']/g,
        character =>
          ({
            "&": "&amp;",
            "<": "&lt;",
            ">": "&gt;",
            '"': "&quot;",
            "'": "&#039;",
          })[character] || character
      );

    const renderFootprintEntry = (record: FootprintRecord) => {
      const entry = document.createElement("article");
      entry.className = "footprint-entry";
      entry.id = `footprint-${record.id}`;
      entry.dataset.locationId = record.id;
      entry.dataset.photoCount = String(record.photos.length);
      entry.addEventListener("lgBeforeOpen", () => {
        isPhotoGalleryOpen = true;
      });
      entry.addEventListener("lgAfterClose", () => {
        isPhotoGalleryOpen = false;
      });

      const entryHeading = document.createElement("header");
      entryHeading.className = "footprint-entry-heading";

      const visitedAt = new Date(record.visitedAt);
      const date = document.createElement("time");
      date.className = "footprint-date";
      date.dateTime = record.visitedAt;
      date.textContent = `${yearFormatter.format(visitedAt)}/${monthFormatter.format(visitedAt)}/${dayFormatter.format(visitedAt)} ${weekdayFormatter.format(visitedAt)}`;

      const place = document.createElement("h3");
      const placeText = document.createElement("span");
      placeText.textContent = record.place;
      place.append(createPinIcon(), placeText);

      entryHeading.append(place, date);

      const photoGrid = document.createElement("div");
      photoGrid.className = "footprint-photo-grid";
      photoGrid.id = `footprint-photos-${record.id}`;
      photoGrid.dataset.layout =
        record.photos.length === 1
          ? "single"
          : record.photos.length === 4
            ? "quad"
            : "triple";

      record.photos.forEach(photo => {
        const link = document.createElement("a");
        link.className = "footprint-photo";
        link.href = photo.original;
        link.dataset.src = photo.original;
        link.dataset.lgSize = `${photo.width}-${photo.height}`;
        link.dataset.subHtml = `<div class="footprint-gallery-caption"><h4>${escapeHTML(photo.alt)}</h4>${photo.caption ? `<p>${escapeHTML(photo.caption)}</p>` : ""}</div>`;
        link.setAttribute("aria-label", `查看大图：${photo.alt}`);

        const image = document.createElement("img");
        image.src = photo.thumbnail;
        image.alt = photo.alt;
        image.width = photo.width;
        image.height = photo.height;
        image.loading = "lazy";
        image.decoding = "async";
        image.style.objectPosition = photo.position || "center";
        link.append(image);

        photoGrid.append(link);
      });

      entry.append(entryHeading);
      if (record.note) {
        const note = document.createElement("p");
        note.className = "footprint-note";
        note.textContent = record.note;
        entry.append(note);
      }
      if (record.relatedPosts.length > 0) {
        const related = document.createElement("nav");
        related.className = "footprint-related-posts";
        related.setAttribute("aria-label", `${record.place}的相关文章`);

        const list = document.createElement("ul");
        record.relatedPosts.forEach(post => {
          const item = document.createElement("li");
          const link = document.createElement("a");
          link.href = post.href;
          link.target = "_blank";
          link.rel = "noopener noreferrer";
          const title = document.createElement("span");
          title.textContent = post.title;
          link.append(
            createRelatedIcon("article"),
            title,
            createRelatedIcon("arrow")
          );
          item.append(link);
          list.append(item);
        });

        if (record.relatedPosts.length === 1) {
          related.classList.add("is-single");
          related.append(list);
        } else {
          const disclosure = document.createElement("details");
          disclosure.className = "footprint-related-disclosure";

          const summary = document.createElement("summary");
          const count = document.createElement("span");
          count.textContent = `${record.relatedPosts.length} 篇关联文章`;
          summary.append(
            createRelatedIcon("article"),
            count,
            createRelatedIcon("chevron")
          );

          disclosure.append(summary, list);
          related.append(disclosure);
        }
        entry.append(related);
      }
      entry.append(photoGrid);
      return entry;
    };

    const destroyGalleries = () => {
      galleryInstances.forEach(instance => instance.destroy());
      galleryInstances = [];
      isPhotoGalleryOpen = false;
    };

    const refreshGallery = async () => {
      if (!gallery.querySelector(".footprint-photo")) return;

      try {
        const [
          { default: lightGallery },
          { default: lgZoom },
          { default: lgThumbnail },
        ] = await Promise.all([
          import("lightgallery"),
          import("lightgallery/plugins/zoom"),
          import("lightgallery/plugins/thumbnail"),
        ]);
        destroyGalleries();
        galleryInstances = Array.from(
          gallery.querySelectorAll<HTMLElement>(".footprint-entry")
        )
          .filter(entry => entry.querySelector(".footprint-photo"))
          .map(entry =>
            lightGallery(entry, {
              plugins: [lgZoom, lgThumbnail],
              selector: ".footprint-photo",
              speed: 350,
              download: false,
              counter: true,
              getCaptionFromTitleOrAlt: false,
              actualSize: false,
              thumbnail: true,
              animateThumb: true,
            })
          );
      } catch {
        // 加载失败时图片链接仍可直接打开原图。
      }
    };

    const loadNextPage = async (version = selectionVersion) => {
      if (
        isLoading ||
        version !== selectionVersion ||
        loadedCount >= activeIds.length
      ) {
        return;
      }

      const pageIds = activeIds.slice(loadedCount, loadedCount + PAGE_SIZE);
      isLoading = true;
      empty.hidden = true;
      loadMoreButton.disabled = true;
      loadMoreButton.textContent = "正在加载…";

      try {
        const records = await Promise.all(
          pageIds.map(async id => {
            const response = await fetch(
              `/api/footprints/${encodeURIComponent(id)}.json`,
              { cache: "force-cache" }
            );
            if (!response.ok) {
              throw new Error(`Failed to load footprint ${id}`);
            }
            return (await response.json()) as FootprintRecord;
          })
        );

        if (version !== selectionVersion) return;
        gallery.append(...records.map(renderFootprintEntry));
        loadedCount += pageIds.length;
        empty.hidden = gallery.childElementCount > 0;
        loadMoreButton.hidden = loadedCount >= activeIds.length;
        await refreshGallery();
      } catch (error) {
        if (version !== selectionVersion) return;
        console.error("Failed to render footprint records", error);
        empty.textContent = "记录加载失败，请稍后再试。";
        empty.hidden = false;
      } finally {
        if (version === selectionVersion) {
          isLoading = false;
          loadMoreButton.disabled = false;
          loadMoreButton.textContent = "加载更多";
        }
      }
    };

    const selectFootprints = (locationIds?: string[]) => {
      selectionVersion += 1;
      isLoading = false;
      loadedCount = 0;
      activeIds = locationIds
        ? [...new Set(locationIds)]
            .filter(id => locationById.has(id))
            .sort(
              (a, b) =>
                (locationById.get(a)?.index ?? 0) -
                (locationById.get(b)?.index ?? 0)
            )
        : [];

      const selectedIds = new Set(activeIds);
      const selectedPhotoCount = activeIds.reduce(
        (total, id) => total + (locationById.get(id)?.photoCount ?? 0),
        0
      );

      destroyGalleries();
      gallery.replaceChildren();
      if (activeIds.length) {
        if (panelState === "closed") setPanelState("half");
        panelBody.scrollTop = 0;
      } else {
        setPanelState("closed");
      }
      markers.forEach((marker, id) => {
        marker
          .getElement()
          ?.querySelector(".photo-map-marker")
          ?.classList.toggle("is-selected", selectedIds.has(id));
      });

      heading.textContent = activeIds.length
        ? shareLocation(activeIds)
          ? `同一地点 · ${activeIds.length} 条足迹 · ${selectedPhotoCount} 张照片`
          : `当前标记 · ${selectedPhotoCount} 张照片`
        : "当前标记";
      empty.textContent = activeIds.length
        ? "正在加载照片记录…"
        : "点击地图上的照片标记查看记录。";
      empty.hidden = false;
      loadMoreButton.hidden = true;

      if (activeIds.length) void loadNextPage(selectionVersion);
    };

    const closePanelForManualZoom = () => {
      if (panelState !== "closed") selectFootprints();
    };
    mapElement.addEventListener("wheel", closePanelForManualZoom, {
      passive: true,
    });
    mapElement.addEventListener("dblclick", closePanelForManualZoom);
    mapElement.addEventListener(
      "touchstart",
      event => {
        if (event.touches.length > 1) closePanelForManualZoom();
      },
      { passive: true }
    );
    mapElement.addEventListener("keydown", event => {
      if (["+", "-", "=", "_"].includes(event.key)) {
        closePanelForManualZoom();
      }
    });

    const resetMapView = (animate = true) => {
      map.stop();

      const moveToInitialView = (center: L.LatLngExpression, zoom: number) => {
        if (!animate) {
          map.setView(center, zoom, { animate: false });
        } else if (Math.abs(map.getZoom() - zoom) < 0.001) {
          // 缩放级别没有变化时只平移，避免同级瓦片被重新缩放而模糊。
          map.panTo(center, { animate: true, duration: 0.55 });
        } else {
          map.flyTo(center, zoom, { duration: 0.8 });
        }
      };

      if (bounds.length > 1) {
        const edgePadding = mobilePanelQuery.matches ? 32 : 64;
        const verticalOffset = mobilePanelQuery.matches ? 16 : 24;
        const initialBounds = L.latLngBounds(bounds);
        const paddingTopLeft = L.point(
          edgePadding,
          edgePadding + verticalOffset
        );
        const paddingBottomRight = L.point(
          edgePadding,
          edgePadding - verticalOffset
        );
        const targetZoom = map.getBoundsZoom(
          initialBounds,
          false,
          paddingTopLeft.add(paddingBottomRight)
        );
        const paddingOffset = paddingBottomRight
          .subtract(paddingTopLeft)
          .divideBy(2);
        const southWestPoint = map.project(
          initialBounds.getSouthWest(),
          targetZoom
        );
        const northEastPoint = map.project(
          initialBounds.getNorthEast(),
          targetZoom
        );
        const targetCenter = map.unproject(
          southWestPoint
            .add(northEastPoint)
            .divideBy(2)
            .add(paddingOffset),
          targetZoom
        );

        moveToInitialView(targetCenter, targetZoom);
      } else if (bounds.length === 1) {
        moveToInitialView(bounds[0], 10);
      } else {
        moveToInitialView([35.8617, 104.1954], 4);
      }
    };

    for (const [locationIndex, location] of locations.entries()) {
      const icon = L.divIcon({
        className: "footprint-map-icon",
        html: createPhotoMarkerContent(location.cover, location.photoCount),
        iconSize: [44, 51],
        iconAnchor: [22, 50],
      });

      const marker = L.marker(
        [location.coordinates.lat, location.coordinates.lng],
        {
          icon,
          title: `${new Date(location.visitedAt).toLocaleDateString("zh-CN", {
            timeZone: timezone,
          })}，${location.photoCount} 张照片`,
          keyboard: false,
          interactive: true,
          pane: "footprint-point-pane",
          riseOnHover: true,
          zIndexOffset: (locations.length - locationIndex) * 1000,
        }
      );

      marker.on("click", () => {
        selectFootprints([location.id]);
        // 叶子标记只移动到可视区域中心，不改变当前缩放级别。
        moveToPanelAwareCenter(
          [location.coordinates.lat, location.coordinates.lng],
          map.getZoom()
        );
      });
      markerVisualData.set(marker, {
        id: location.id,
        cover: location.cover,
        photoCount: location.photoCount,
      });
      markerClusters.addLayer(marker);
      markers.set(location.id, marker);
      bounds.push([location.coordinates.lat, location.coordinates.lng]);
    }

    type ExpandableMarkerCluster = L.MarkerCluster & {
      _zoom?: number;
      _childClusters?: ExpandableMarkerCluster[];
      _markers?: L.Marker[];
    };
    const getClusterExpansionZoom = (cluster: ExpandableMarkerCluster) => {
      let bottomCluster = cluster;

      while (
        bottomCluster._childClusters?.length === 1 &&
        bottomCluster._markers?.length === 0
      ) {
        bottomCluster = bottomCluster._childClusters[0];
      }

      return Math.min(
        (bottomCluster._zoom ?? map.getZoom()) + 1,
        map.getMaxZoom()
      );
    };

    markerClusters.on("clusterclick", event => {
      const cluster = (event as unknown as { layer: ExpandableMarkerCluster })
        .layer;
      const selectedIds = cluster
        .getAllChildMarkers()
        .map((marker: L.Marker) => markerVisualData.get(marker)?.id)
        .filter((id: string | undefined): id is string => Boolean(id));
      const isSameLocation = shareLocation(selectedIds);
      const distinctPlaceCount = new Set(
        selectedIds
          .map(id => locationById.get(id)?.placeGroup)
          .filter((placeGroup): placeGroup is number =>
            Number.isInteger(placeGroup)
          )
      ).size;
      const expansionZoom = getClusterExpansionZoom(cluster);
      const shouldZoomIn = !isSameLocation && expansionZoom > map.getZoom();
      const shouldLoadDetails =
        distinctPlaceCount <= MAX_CLUSTER_PLACE_COUNT_TO_LOAD;

      // 同一地点的多次足迹只计作一个地点。地点超过 3 个时仅拆分聚合，
      // 不打开详情面板，避免一次触发大量记录请求。
      if (shouldLoadDetails) {
        selectFootprints(selectedIds);
      } else {
        selectFootprints();
      }
      // 同一地点无法继续拆分时仍需重新定位；保持缩放级别，只将标记
      // 移到右侧面板之外的地图视觉中心。
      if (shouldZoomIn || (shouldLoadDetails && isSameLocation)) {
        moveToPanelAwareCenter(
          cluster.getLatLng(),
          shouldZoomIn ? expansionZoom : map.getZoom()
        );
      }
    });

    type FootprintsView = "map" | "timeline";
    const VIEW_STORAGE_KEY = "footprints-preferred-view";
    let hasFittedInitialMapView = false;
    const setActiveView = (view: FootprintsView, persist = true) => {
      const showMap = view === "map";
      mapShell.hidden = !showMap;
      mapShell.toggleAttribute("inert", !showMap);
      timelinePanel.hidden = showMap;
      timelinePanel.toggleAttribute("inert", showMap);

      viewTabs.forEach(tab => {
        const isActive = tab.dataset.footprintsView === view;
        tab.setAttribute("aria-selected", String(isActive));
        tab.tabIndex = isActive ? 0 : -1;
        if (isActive) {
          viewIndicator.style.width = `${tab.offsetWidth}px`;
          viewIndicator.style.transform = `translate3d(${tab.offsetLeft}px, 0, 0)`;
          viewIndicator.style.opacity = "1";
        }
      });

      if (persist) {
        try {
          localStorage.setItem(VIEW_STORAGE_KEY, view);
        } catch {
          // 隐私模式下无法持久化时，当前页面内的切换仍然有效。
        }
      }

      if (showMap) {
        requestAnimationFrame(() => {
          updateMapViewportHeight();
          map.invalidateSize({ pan: false });
          if (!hasFittedInitialMapView) {
            resetMapView(false);
            hasFittedInitialMapView = true;
          }
        });
      }
    };

    viewTabs.forEach((tab, index) => {
      tab.addEventListener("click", () => {
        setActiveView(tab.dataset.footprintsView as FootprintsView);
      });
      tab.addEventListener("keydown", event => {
        if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) {
          return;
        }
        event.preventDefault();
        const nextIndex =
          event.key === "Home"
            ? 0
            : event.key === "End"
              ? viewTabs.length - 1
              : (index +
                  (event.key === "ArrowRight" ? 1 : -1) +
                  viewTabs.length) %
                viewTabs.length;
        const nextTab = viewTabs[nextIndex];
        nextTab.focus();
        setActiveView(nextTab.dataset.footprintsView as FootprintsView);
      });
    });

    let preferredView: FootprintsView = "map";
    try {
      if (localStorage.getItem(VIEW_STORAGE_KEY) === "timeline") {
        preferredView = "timeline";
      }
    } catch {
      // 使用默认地图视图。
    }
    setActiveView(preferredView, false);

    const zoomControl = mapZoomControl.getContainer();
    if (zoomControl) {
      zoomControl.addEventListener(
        "click",
        event => {
          if (
            event.target instanceof Element &&
            event.target.closest(
              ".leaflet-control-zoom-in, .leaflet-control-zoom-out"
            )
          ) {
            closePanelForManualZoom();
          }
        },
        true
      );
      const createControlIcon = (pathData: string) => {
        const icon = document.createElementNS(
          "http://www.w3.org/2000/svg",
          "svg"
        );
        icon.setAttribute("viewBox", "0 0 24 24");
        icon.setAttribute("aria-hidden", "true");
        const path = document.createElementNS(
          "http://www.w3.org/2000/svg",
          "path"
        );
        path.setAttribute("d", pathData);
        icon.append(path);
        return icon;
      };
      const resetButton = document.createElement("a");
      resetButton.className = "leaflet-control-initial-view";
      resetButton.href = "#";
      resetButton.title = "恢复初始视图";
      resetButton.setAttribute("role", "button");
      resetButton.setAttribute("aria-label", "恢复初始视图");
      resetButton.append(
        createControlIcon("M4 10.5 12 4l8 6.5M6.5 9v10h11V9M9.5 19v-6h5v6")
      );
      resetButton.addEventListener("click", event => {
        event.preventDefault();
        event.stopPropagation();
        selectFootprints();
        resetMapView();
      });
      zoomControl.insertBefore(resetButton, zoomControl.firstChild);

      zoomControl
        .querySelector(".leaflet-control-zoom-in")
        ?.replaceChildren(createControlIcon("M12 5v14M5 12h14"));
      zoomControl
        .querySelector(".leaflet-control-zoom-out")
        ?.replaceChildren(createControlIcon("M5 12h14"));
    }

    loadMoreButton.addEventListener("click", () => {
      void loadNextPage();
    });
    panelExpandButton.addEventListener("click", () => {
      setPanelState(panelState === "expanded" ? "half" : "expanded");
    });
    panelCloseButton.addEventListener("click", () => {
      selectFootprints();
    });
    document.addEventListener("keydown", event => {
      if (
        event.key === "Escape" &&
        !isPhotoGalleryOpen &&
        panel.isConnected &&
        panelState !== "closed"
      ) {
        selectFootprints();
      }
    });
    document.addEventListener(
      "astro:before-swap",
      () => {
        window.removeEventListener("resize", updateMapViewportHeight);
        window.removeEventListener("scroll", scheduleToolbarPinnedUpdate);
        window.removeEventListener("resize", scheduleToolbarPinnedUpdate);
        if (toolbarPinnedFrame !== null) {
          cancelAnimationFrame(toolbarPinnedFrame);
        }
        document.removeEventListener(
          "mousedown",
          blockSecondaryGalleryDrag,
          true
        );
        document.removeEventListener(
          "contextmenu",
          releaseGalleryDragAfterContextMenu,
          true
        );
        overviewResizeObserver.disconnect();
      },
      { once: true }
    );
  };

  initializeFootprints();
  document.addEventListener("astro:page-load", initializeFootprints);
</script>

